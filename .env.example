# Assistant Configuration
ASSISTANT_NAME=Andy
ASSISTANT_HAS_OWN_NUMBER=false

# ============================================================================
# LLM Provider Configuration
# ============================================================================
# Choose ONE provider below and configure its settings
# Valid providers: claude, openai, openrouter, openai-compatible

# ----------------------------------------------------------------------------
# Option 1: Claude (Anthropic) - DEFAULT
# ----------------------------------------------------------------------------
LLM_PROVIDER=claude
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# ANTHROPIC_BASE_URL=https://api.anthropic.com  # Optional: custom endpoint
# LLM_MODEL=claude-3-5-sonnet-20241022  # Optional: defaults to this

# ----------------------------------------------------------------------------
# Option 2: OpenAI
# ----------------------------------------------------------------------------
# LLM_PROVIDER=openai
# OPENAI_API_KEY=your_openai_api_key_here
# LLM_MODEL=gpt-4-turbo  # or gpt-4, gpt-3.5-turbo, etc.
# LLM_BASE_URL=https://api.openai.com/v1  # Optional: auto-set for openai provider

# ----------------------------------------------------------------------------
# Option 3: OpenRouter (access to multiple models)
# ----------------------------------------------------------------------------
# LLM_PROVIDER=openrouter
# OPENROUTER_API_KEY=your_openrouter_api_key_here
# LLM_MODEL=anthropic/claude-3.5-sonnet  # or openai/gpt-4-turbo, etc.
# LLM_BASE_URL=https://openrouter.ai/api/v1  # Optional: auto-set for openrouter provider

# ----------------------------------------------------------------------------
# Option 4: Other OpenAI-Compatible APIs (Together AI, Groq, etc.)
# ----------------------------------------------------------------------------
# LLM_PROVIDER=openai-compatible
# OPENAI_API_KEY=your_api_key_here  # Use OPENAI_API_KEY for generic providers
# LLM_BASE_URL=https://api.together.xyz/v1  # REQUIRED: your provider's base URL
# LLM_MODEL=meta-llama/Llama-3-70b-chat-hf  # Provider-specific model name

# Examples for other providers:
# Together AI: LLM_BASE_URL=https://api.together.xyz/v1
# Groq: LLM_BASE_URL=https://api.groq.com/openai/v1
# Perplexity: LLM_BASE_URL=https://api.perplexity.ai
# Anyscale: LLM_BASE_URL=https://api.endpoints.anyscale.com/v1

# ============================================================================
# Model Parameters (Optional - applies to all providers)
# ============================================================================
# LLM_TEMPERATURE=0.7  # 0-1, controls randomness
# LLM_MAX_TOKENS=4096  # Maximum completion tokens
# LLM_TOP_P=1.0  # Nucleus sampling parameter

# ============================================================================
# Retry Configuration (Optional)
# ============================================================================
# LLM_MAX_RETRIES=3  # Number of retry attempts on failure
# LLM_RETRY_DELAY=1000  # Milliseconds between retries (exponential backoff)

# ============================================================================
# Fallback Configuration (Optional)
# ============================================================================
# If primary provider fails after retries, fall back to this provider
# LLM_FALLBACK_PROVIDER=claude  # or openai, openrouter, openai-compatible
# LLM_FALLBACK_MODEL=claude-3-5-sonnet-20241022

# ============================================================================
# Stagehand Browser Automation (Optional)
# ============================================================================
# AI-powered browser automation for complex workflows
# Requires LLM API calls (adds cost but provides flexibility)

# Enable/disable Stagehand
STAGEHAND_ENABLED=true

# Usage limits (prevent runaway costs)
STAGEHAND_MAX_ACTIONS_PER_SESSION=10  # Max AI actions per session
STAGEHAND_COST_LIMIT=0.50  # Max cost per session in USD

# Fallback behavior
STAGEHAND_FALLBACK_TO_AGENT_BROWSER=true  # Use agent-browser when limits reached

# ============================================================================
# Container Configuration
# ============================================================================
# CONTAINER_IMAGE=nanoclaw-agent:latest
# CONTAINER_TIMEOUT=1800000  # 30 minutes in milliseconds
# IDLE_TIMEOUT=1800000  # 30 minutes in milliseconds
# MAX_CONCURRENT_CONTAINERS=5

# ============================================================================
# Claude Code OAuth (Optional - for agent features)
# ============================================================================
# CLAUDE_CODE_OAUTH_TOKEN=your_oauth_token_here

# ============================================================================
# Quick Setup Examples
# ============================================================================

# Example 1: Use Claude (simplest, default)
# LLM_PROVIDER=claude
# ANTHROPIC_API_KEY=sk-ant-xxxxx

# Example 2: Use OpenAI GPT-4
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-xxxxx
# LLM_MODEL=gpt-4-turbo

# Example 3: Use OpenRouter with Claude (cost-effective)
# LLM_PROVIDER=openrouter
# OPENROUTER_API_KEY=sk-or-xxxxx
# LLM_MODEL=anthropic/claude-3.5-sonnet

# Example 4: Use OpenRouter with GPT-4
# LLM_PROVIDER=openrouter
# OPENROUTER_API_KEY=sk-or-xxxxx
# LLM_MODEL=openai/gpt-4-turbo

# Example 5: Use Together AI
# LLM_PROVIDER=openai-compatible
# OPENAI_API_KEY=xxxxx
# LLM_BASE_URL=https://api.together.xyz/v1
# LLM_MODEL=meta-llama/Llama-3-70b-chat-hf

# Example 6: Use Groq (fast inference)
# LLM_PROVIDER=openai-compatible
# OPENAI_API_KEY=gsk_xxxxx
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_MODEL=llama3-70b-8192
