# Assistant Configuration
ASSISTANT_NAME=Andy
ASSISTANT_HAS_OWN_NUMBER=false

# Claude API (default provider)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# ANTHROPIC_BASE_URL=https://api.anthropic.com  # Optional: custom endpoint

# LLM Configuration (Global Defaults)
# Provider: 'claude' (default) or 'openai' (for OpenAI-compatible APIs)
LLM_PROVIDER=claude

# OpenAI-compatible API Configuration
# Use these for OpenRouter, Together AI, Groq, or any OpenAI-compatible API
# OPENAI_API_KEY=your_openai_api_key_here
# OPENROUTER_API_KEY=your_openrouter_api_key_here
# LLM_BASE_URL=https://api.openai.com/v1  # or https://openrouter.ai/api/v1
# LLM_MODEL=gpt-4-turbo  # Model to use (provider-specific)

# Model Parameters (optional, defaults shown)
# LLM_TEMPERATURE=0.7
# LLM_MAX_TOKENS=4096
# LLM_TOP_P=1.0

# Retry Configuration
# LLM_MAX_RETRIES=3
# LLM_RETRY_DELAY=1000  # milliseconds

# Fallback Configuration
# If primary provider fails after retries, fall back to this provider
# LLM_FALLBACK_PROVIDER=claude
# LLM_FALLBACK_MODEL=claude-3-5-sonnet-20241022

# Container Configuration
# CONTAINER_IMAGE=nanoclaw-agent:latest
# CONTAINER_TIMEOUT=1800000  # 30 minutes
# IDLE_TIMEOUT=1800000  # 30 minutes
# MAX_CONCURRENT_CONTAINERS=5

# Claude Code OAuth (for agent features)
# CLAUDE_CODE_OAUTH_TOKEN=your_oauth_token_here
